.DS_Store
.claude/

# Per-company deployment config (contains Firebase keys)
# Vite serves frontend/public/ at site root; deploy/deploy.sh がテナントごとに生成する成果物。
frontend/public/app-config.js
.firebaserc

# テナント定義（実値）。_example.env テンプレのみコミットする
deploy/tenants/*.env
!deploy/tenants/_example.env

# Vite / Node
node_modules/
frontend/dist/

# Backend
backend/node_modules
backend/.env
backend/.env.*
!backend/.env.example
backend/sa-key.json

# Firebase CLI cache
.firebase/
firebase-debug.log
firebase-debug.*.log
