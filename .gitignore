.firebaserc

# テナント定義（実値）。_example.env テンプレのみコミットする
deploy/tenants/*.env
!deploy/tenants/_example.env

# Backend
backend/node_modules
backend/.env
backend/.env.*
!backend/.env.example
backend/sa-key.json

# Firebase CLI cache
.firebase/
