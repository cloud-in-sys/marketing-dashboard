# テナント定義テンプレート。
# このファイルをコピーして deploy/tenants/<tenant>.env を作成し、値を埋める。
#   cp deploy/tenants/_example.env deploy/tenants/acme.env
# <tenant>.env は gitignore される（このテンプレのみコミット）。
# 値は Firebase Console > プロジェクト設定 > 全般 > マイアプリ > SDK snippet から取得。

# テナント識別名（ファイル名と揃える）
TENANT=acme

# GCP / Firebase プロジェクトID（全世界でユニーク）
PROJECT_ID=acme-dashboard
# プロジェクト番号（appId 内の数値部分。OAuth redirect URI のホスト名に使う）
#   gcloud projects describe $PROJECT_ID --format='value(projectNumber)'
PROJECT_NUMBER=000000000000
# デプロイ先リージョン（既存は asia-northeast1）
REGION=asia-northeast1

# Firebase Web SDK 設定
API_KEY=REPLACE_ME
APP_ID=1:000000000000:web:REPLACE_ME
APP_NAME="ACME Dashboard"

# App Check (reCAPTCHA v3 site key)。未使用なら空のままでよい（公開情報）。
APP_CHECK_SITE_KEY=

# Google OAuth クライアントID（Sheets/BQ 連携用）。backend デプロイ時に必須。
#   Google Cloud Console > APIs & Services > Credentials の OAuth 2.0 クライアントID
GOOGLE_OAUTH_CLIENT_ID=000000000000-xxxxx.apps.googleusercontent.com

# メトリクス集計を Cloud Run に委譲するか
USE_BACKEND_AGGREGATE=true
