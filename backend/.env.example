# GCP / Firebase
GCP_PROJECT_ID=your-project-id

# Google OAuth (for Sheets/BQ linking)
# Get client ID from Google Cloud Console > APIs & Services > Credentials
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
# OAuth redirect URI — must match what's registered in Google Cloud Console.
# On Cloud Run: https://your-service-xxxxx.run.app/api/google/auth/callback
# Locally: http://localhost:8080/api/google/auth/callback
OAUTH_REDIRECT_URI=http://localhost:8080/api/google/auth/callback

# CORS origins (comma-separated). Leave empty if using Firebase Hosting rewrites (same-origin).
ALLOWED_ORIGINS=

# For local dev: path to service account key JSON
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json

NODE_ENV=development
PORT=8080
